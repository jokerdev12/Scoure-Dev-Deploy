# Environment variables example for backend and bot

# Telegram bot
TELEGRAM_BOT_TOKEN=

# App
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/jokersmile
REDIS_URL=redis://localhost:6379/0
BASE_WEB_URL=http://localhost:3000

# Storage (S3-compatible)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Payment
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: local GPU server
LOCAL_INFERENCE_URL=http://localhost:7860
